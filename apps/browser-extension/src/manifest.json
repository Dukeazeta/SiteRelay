{
  "manifest_version": 3,
  "name": "SiteRelay Capture",
  "version": "0.1.0",
  "description": "Select a rendered web component and relay its structure, styling, typography, assets, animation, and screenshot to Codex.",
  "permissions": ["activeTab", "alarms", "debugger", "scripting", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:4319/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Capture with SiteRelay",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
